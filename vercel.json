{
  "version": 2,
  "framework": "vite",
  "rootDirectory": "apps/web",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/web/"
}
