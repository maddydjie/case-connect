# Database
DATABASE_URL=postgresql://caseconnect:caseconnect_secret@localhost:5432/caseconnect?schema=public
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://caseconnect:caseconnect_secret@localhost:27017/caseconnect

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.caseconnect.in
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# MinIO (S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=caseconnect
MINIO_SECRET_KEY=caseconnect_secret
MINIO_BUCKET=caseconnect-files

# Kong Gateway
KONG_ADMIN_URL=http://localhost:8001
KONG_PROXY_URL=http://localhost:8000

# Voice AI
VOICE_AI_URL=http://localhost:8100
WHISPER_MODEL=large-v3

# Notifications
MSG91_AUTH_KEY=your-msg91-key
MSG91_SENDER_ID=CSCONN

# General
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
